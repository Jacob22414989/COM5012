#include <iostream>
#include <string>

using namespace std;

class book {
	protected:
		int id;
		string title;
		bool isAvailable;
		int reservedBy;
		int chechedOutOn;

	public:
		book(int id, const string& title )
			: id(id), title(title),isAvailable(true), reservedBy(0), chechedOutOn(0) {}
};



