#include <iostream>
#include <vector>
#include <string>
#include <algorithm>
#include <limits>

using namespace std;

class Library;
class Customer;
class Librarian;

class LibraryItem {
protected:
    int    id;
    string title;
    string author;
    int    year;
    bool   available;
    int    checkedOutBy;
    int    reservedBy;

public:
    LibraryItem(int id, const string& title, const string& author, int year)
        : id(id), title(title), author(author), year(year),
        available(true), checkedOutBy(0), reservedBy(0) {
    }

    virtual ~LibraryItem() {}

    int    getId()           const { return id; }
    string getTitle()        const { return title; }
    string getAuthor()       const { return author; }
    bool   isAvailable()     const { return available; }
    int    getCheckedOutBy() const { return checkedOutBy; }
    int    getReservedBy()   const { return reservedBy; }

    bool checkOut(int userId) {
        if (!available) return false;
        available = false;
        checkedOutBy = userId;
        reservedBy = 0;
        return true;
    }
    bool returnBook() {
        if (available) return false;
        available = true;
        checkedOutBy = 0;
        return true;
    }
    bool reserve(int userId) {
        if (!available || reservedBy != 0) return false;
        reservedBy = userId;
        return true;
    }

    virtual string getType()     const = 0;
    virtual void   displayInfo() const = 0;
};

class Book : public LibraryItem {
    string genre, isbn;
    int    pages;
public:
    Book(int id, const string& t, const string& a, int yr,
        const string& genre, int pages, const string& isbn)
        : LibraryItem(id, t, a, yr), genre(genre), isbn(isbn), pages(pages) {
    }

    string getType() const override { return "Book"; }
    void displayInfo() const override {
        string status;
        if (available)
            status = reservedBy ? "Reserved (uid:" + to_string(reservedBy) + ")" : "Available";
        else
            status = "Checked out (uid:" + to_string(checkedOutBy) + ")";
        cout << "  [BOOK] #" << id << "  \"" << title << "\""
            << "  by " << author << "  (" << year << ")"
            << "  Genre:" << genre << status << "\n";
    }
};


class User {
protected:
    int    id;
    string name;
    string password;
    string role;

public:
    User(int id, const string& name, const string& pwd, const string& role)
        : id(id), name(name), password(pwd), role(role) {
    }

    virtual ~User() {}

    int    getId()                       const { return id; }
    string getName()                     const { return name; }
    string getRole()                     const { return role; }
    bool   authenticate(const string& p) const { return p == password; }

    virtual void showMenu()        const = 0;
    virtual void handleMenu(Library&) = 0;
};


class Library {
private:
    vector<LibraryItem*> items;
    vector<User*>        users;
    int nextItemId = 1;
    int nextUserId = 1;

    static void hdr(const string& t) {
        cout << "\n\n"
            << "  " << t << "\n"
            << "\n";
    }

public:
    Library();
    ~Library() {
        for (auto p : items) delete p;
        for (auto p : users) delete p;
    }

    void showAllItems() const {
        hdr("ALL ITEMS");
        for (auto& i : items) i->displayInfo();
    }
    void showAvailableItems() const {
        hdr("AVAILABLE ITEMS");
        bool any = false;
        for (auto& i : items) if (i->isAvailable()) { i->displayInfo(); any = true; }
        if (!any) cout << "  Nothing available right now.\n";
    }
    void searchItems(const string& kw) const {
        hdr("SEARCH: \"" + kw + "\"");
        string k = kw;
        transform(k.begin(), k.end(), k.begin(), ::tolower);
        bool any = false;
        for (auto& i : items) {
            string t = i->getTitle(), a = i->getAuthor();
            transform(t.begin(), t.end(), t.begin(), ::tolower);
            transform(a.begin(), a.end(), a.begin(), ::tolower);
            if (t.find(k) != string::npos || a.find(k) != string::npos)
            {
                i->displayInfo(); any = true;
            }
        }
        if (!any) cout << "  No results.\n";
    }

    void checkOutItem(int itemId, int userId) {
        for (auto& i : items) {
            if (i->getId() == itemId) {
                if (i->checkOut(userId))
                    cout << "  \xE2\x9C\x93 Checked out: \"" << i->getTitle() << "\"\n";
                else
                    cout << "  \xE2\x9C\x97 \"" << i->getTitle() << "\" is not available.\n";
                return;
            }
        }
        cout << "  \xE2\x9C\x97 Item #" << itemId << " not found.\n";
    }
    void returnItem(int itemId) {
        for (auto& i : items) {
            if (i->getId() == itemId) {
                if (i->returnBook())
                    cout << "  \xE2\x9C\x93 Returned: \"" << i->getTitle() << "\"\n";
                else
                    cout << "  \xE2\x9C\x97 That item was not checked out.\n";
                return;
            }
        }
        cout << "  \xE2\x9C\x97 Item #" << itemId << " not found.\n";
    }
    void reserveItem(int itemId, int userId) {
        for (auto& i : items) {
            if (i->getId() == itemId) {
                if (i->reserve(userId))
                    cout << "  \xE2\x9C\x93 Reserved: \"" << i->getTitle() << "\"\n";
                else
                    cout << "  \xE2\x9C\x97 Cannot reserve: item unavailable or already reserved.\n";
                return;
            }
        }
        cout << "  \xE2\x9C\x97 Item #" << itemId << " not found.\n";
    }

    // librarian
    void addBookPrompt() {
        string title, author, genre, isbn;
        int year, pages;
        cin.ignore(numeric_limits<streamsize>::max(), '\n');
        cout << "  Title   : "; getline(cin, title);
        cout << "  Author  : "; getline(cin, author);
        cout << "  Genre   : "; getline(cin, genre);
        cout << "  Year    : "; cin >> year;
        cout << "  Pages   : "; cin >> pages;
        cin.ignore(); cout << "  ISBN    : "; getline(cin, isbn);
        int nid = nextItemId++;
        items.push_back(new Book(nid, title, author, year, genre, pages, isbn));
        cout << "  \xE2\x9C\x93 Book added (ID #" << nid << ").\n";
    }
    void removeItem(int itemId) {
        for (auto it = items.begin(); it != items.end(); ++it) {
            if ((*it)->getId() == itemId) {
                cout << "  \xE2\x9C\x93 Removed: \"" << (*it)->getTitle() << "\"\n";
                delete* it; items.erase(it); return;
            }
        }
        cout << "  \xE2\x9C\x97 Item #" << itemId << " not found.\n";
    }
    // manager
    void listUsers()  const;
    void addUserPrompt(const string& role);
    void removeUser(int userId);

    User* findUser(const string& name, const string& pwd) {
        for (auto& u : users)
            if (u->getName() == name && u->authenticate(pwd)) return u;
        return nullptr;
    }
    int  getNextUserId() { return nextUserId++; }
    void addUser(User* u) { users.push_back(u); }
};

class Customer : public User {
public:
    Customer(int id, const string& name, const string& pwd)
        : User(id, name, pwd, "Customer") {
    }

    void showMenu() const override {
        cout << "\n   Customer Menu (" << name << ") \n"
            << "    1. Browse all items                           \n"
            << "    2. Search items                               \n"
            << "    3. Check out item                             \n"
            << "    4. Return item                                \n"
            << "    5. Reserve item                               \n"
            << "    0. Logout                                     \n"
            << "  \n";
    }

    void handleMenu(Library& lib) override {
        int ch;
        while (true) {
            showMenu();
            cout << "  Choice: "; cin >> ch;
            if (cin.fail()) { cin.clear(); cin.ignore(10000, '\n'); continue; }
            switch (ch) {
            case 1: lib.showAllItems(); break;
            case 2: { string k; cin.ignore(); cout << "  Keyword: "; getline(cin, k); lib.searchItems(k); break; }
            case 3: { int id; cout << "  Item ID: "; cin >> id; lib.checkOutItem(id, this->id); break; }
            case 4: { int id; cout << "  Item ID: "; cin >> id; lib.returnItem(id); break; }
            case 5: { int id; cout << "  Item ID: "; cin >> id; lib.reserveItem(id, this->id); break; }
            case 0: cout << "  Logged out.\n"; return;
            default: cout << "  Invalid option.\n";
            }
        }
    }
};


class Librarian : public Customer {
public:
    Librarian(int id, const string& name, const string& pwd)
        : Customer(id, name, pwd) {
        role = "Librarian";
    }

    void showMenu() const override {
        cout << "\n  Librarian Menu (" << name << ") \n"
            << "    1. Browse all items                            \n"
            << "    2. Search items                                \n"
            << "    3. Check out item                              \n"
            << "    4. Return item                                 \n"
            << "    5. Reserve item                                \n"
            << "    6. Add new Book                                \n"
            << "    7. Remove item                                 \n"
            << "    0. Logout                                      \n"
            << "  \n";
    }

    void handleMenu(Library& lib) override {
        int ch;
        while (true) {
            showMenu();
            cout << "  Choice: "; cin >> ch;
            if (cin.fail()) { cin.clear(); cin.ignore(10000, '\n'); continue; }
            switch (ch) {
            case 1: lib.showAllItems(); break;
            case 2: { string k; cin.ignore(); cout << "  Keyword: "; getline(cin, k); lib.searchItems(k); break; }
            case 3: { int id; cout << "  Item ID: "; cin >> id; lib.checkOutItem(id, this->id); break; }
            case 4: { int id; cout << "  Item ID: "; cin >> id; lib.returnItem(id); break; }
            case 5: { int id; cout << "  Item ID: "; cin >> id; lib.reserveItem(id, this->id); break; }
            case 6: lib.addBookPrompt(); break;
            case 7: { int id; cout << "  Item ID: "; cin >> id; lib.removeItem(id); break; }
            case 0: cout << "  Logged out.\n"; return;
            default: cout << "  Invalid option.\n";
            }
        }
    }
};

class Manager : public Librarian {
public:
    Manager(int id, const string& name, const string& pwd)
        : Librarian(id, name, pwd) {
        role = "Manager";
    }

    void showMenu() const override {
        cout << "\n  Manager Menu (" << name << ")\n"
            << "    Library Items \n"
            << "    1.  Browse all items                           \n"
            << "    2.  Search items                               \n"
            << "    3.  Check out item                             \n"
            << "    4.  Return item                                \n"
            << "    5.  Reserve item                               \n"
            << "    6.  Add new Book                               \n"
            << "    7.  Remove item                                \n"
            << "    User Management \n"
            << "    8.  List all users                             \n"
            << "    9. Add new Customer                            \n"
            << "    10. Add new Librarian                          \n"
            << "    11 Remove a user                               \n"
            << "    0.  Logout                                     \n"
            << "  \n";
    }

    void handleMenu(Library& lib) override {
        int ch;
        while (true) {
            showMenu();
            cout << "  Choice: "; cin >> ch;
            if (cin.fail()) { cin.clear(); cin.ignore(10000, '\n'); continue; }
            switch (ch) {
            case 1:  lib.showAllItems(); break;
            case 2: { string k; cin.ignore(); cout << "  Keyword: "; getline(cin, k); lib.searchItems(k); break; }
            case 3: { int id; cout << "  Item ID: "; cin >> id; lib.checkOutItem(id, this->id); break; }
            case 4: { int id; cout << "  Item ID: "; cin >> id; lib.returnItem(id); break; }
            case 5: { int id; cout << "  Item ID: "; cin >> id; lib.reserveItem(id, this->id); break; }
            case 6:  lib.addBookPrompt(); break;
            case 7: { int id; cout << "  Item ID: "; cin >> id; lib.removeItem(id); break; }
            case 8:  lib.listUsers(); break;
            case 9: lib.addUserPrompt("Customer");  break;
            case 10: lib.addUserPrompt("Librarian"); break;
            case 11: { int id; cout << "  User ID: "; cin >> id; lib.removeUser(id); break; }
            case 0:  cout << "  Logged out.\n"; return;
            default: cout << "  Invalid option.\n";
            }
        }
    }
};

void Library::listUsers() const {
    hdr("ALL USERS");
    for (auto& u : users)
        cout << "  #" << u->getId() << "  [" << u->getRole() << "]  " << u->getName() << "\n";
}

void Library::addUserPrompt(const string& role) {
    string name, pwd;
    cin.ignore(numeric_limits<streamsize>::max(), '\n');
    cout << "  Name     : "; getline(cin, name);
    cout << "  Password : "; getline(cin, pwd);
    int uid = getNextUserId();
    User* u = (role == "Customer")
        ? static_cast<User*>(new Customer(uid, name, pwd))
        : static_cast<User*>(new Librarian(uid, name, pwd));
    addUser(u);
    cout << "  \xE2\x9C\x93 " << role << " \"" << name << "\" created (ID #" << uid << ").\n";
}

void Library::removeUser(int userId) {
    for (auto it = users.begin(); it != users.end(); ++it) {
        if ((*it)->getId() == userId) {
            if ((*it)->getRole() == "Manager") {
                cout << "  \xE2\x9C\x97 Cannot remove a Manager account.\n"; return;
            }
            cout << "  \xE2\x9C\x93 Removed user: \"" << (*it)->getName()
                << "\" [" << (*it)->getRole() << "]\n";
            delete* it; users.erase(it); return;
        }
    }
    cout << "  \xE2\x9C\x97 User #" << userId << " not found.\n";
}

// items
Library::Library() {
    items.push_back(new Book(nextItemId++, "The Great Gatsby", "F. Scott Fitzgerald", 1925, "Classic", 180, "978-0743273565"));
    items.push_back(new Book(nextItemId++, "Clean Code", "Robert C. Martin", 2008, "Tech", 431, "978-0132350884"));
    items.push_back(new Book(nextItemId++, "Dune", "Frank Herbert", 1965, "Sci-Fi", 412, "978-0441013593"));
    items.push_back(new Book(nextItemId++, "1984", "George Orwell", 1949, "Dystopia", 328, "978-0451524935"));

    users.push_back(new Manager(nextUserId++, "admin", "admin123"));
    users.push_back(new Librarian(nextUserId++, "alice", "alice123"));
    users.push_back(new Librarian(nextUserId++, "mario", "mario123"));
    users.push_back(new Customer(nextUserId++, "bob", "bob123"));
    users.push_back(new Customer(nextUserId++, "diana", "diana123"));
}
